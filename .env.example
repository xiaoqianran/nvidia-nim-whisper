# 复制为 .env 后填入真实 Key（.env 已被 .gitignore 忽略，切勿提交）
# cp .env.example .env

# —— NVIDIA Whisper ASR ——
# 单 Key：
# NVIDIA_API_KEY=nvapi-your-key-here
# 多 Key 负载均衡——推荐二选一：
# 1) 逗号分隔
# NVIDIA_API_KEYS=nvapi-key1,nvapi-key2,nvapi-key3
# 2) 外部文件（每行一个，已 gitignore 示例名 nvidia_api_keys.txt）
NVIDIA_API_KEYS_FILE=nvidia_api_keys.txt
# 每个 Key 独立滑动窗口限速（默认 60 次/60s）；总吞吐 ≈ n_keys × 60/min
WHISPER_RATE_LIMIT=60
WHISPER_RATE_WINDOW_SEC=60

# —— NVIDIA 翻译（OpenAI 兼容 + 多 Key 负载均衡）——
# 推荐：翻译专用 Key 文件（每行一个 nvapi-...），与 Whisper ASR Key 分开
NVIDIA_TRANSLATE_API_KEYS_FILE=nvidia_translate_api_keys.txt
OPENAI_BASE_URL=https://integrate.api.nvidia.com/v1
OPENAI_MODEL=mistralai/mistral-small-4-119b-2603
TRANSLATE_TO=zh-CN
# 每把 Key 独立滑动窗口（默认 60/min）；总吞吐 ≈ n_keys × 60
TRANSLATE_RATE_LIMIT=60
TRANSLATE_RATE_WINDOW_SEC=60
# 也兼容别名：
# LLM_API_KEY=
# LLM_BASE_URL=
# LLM_MODEL=

# —— GigaSpeech / HuggingFace streaming ——
# HF_TOKEN=hf_...
# GIGASPEECH_SUBSET=xs
# 限制 HF 缓存目录，避免占满磁盘：
# HF_HOME=/tmp/hf_home


# —— 总结 stepfun-ai/step-3.5-flash（多 Key 每把 40/min）——
NVIDIA_SUMMARIZE_API_KEYS_FILE=nvidia_summarize_api_keys.txt
SUMMARIZE_MODEL=stepfun-ai/step-3.5-flash
SUMMARIZE_RATE_LIMIT=40
SUMMARIZE_RATE_WINDOW_SEC=60
SUMMARIZE_MAX_CHUNK_CHARS=24000
