# 复制为 .env 后填入真实 Key（.env 已被 .gitignore 忽略，切勿提交）
# cp .env.example .env

# —— NVIDIA Whisper ASR ——
# 单 Key：
# NVIDIA_API_KEY=nvapi-your-key-here
# 多 Key 负载均衡（突破单 Key 40/min）—— 推荐二选一：
# 1) 逗号分隔
# NVIDIA_API_KEYS=nvapi-key1,nvapi-key2,nvapi-key3
# 2) 外部文件（每行一个，已 gitignore 示例名 nvidia_api_keys.txt）
NVIDIA_API_KEYS_FILE=nvidia_api_keys.txt
# 每个 Key 独立滑动窗口限速（默认 40 次/60s）；总吞吐 ≈ n_keys × 40/min
WHISPER_RATE_LIMIT=40
WHISPER_RATE_WINDOW_SEC=60

# —— OpenAI 兼容翻译（--translate 时需要）——
# base 需带 /v1（NewAPI / OneAPI 等网关同理）
OPENAI_API_KEY=sk-your-key-here
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_MODEL=gpt-4o-mini
# 示例（NewAPI）:
# OPENAI_BASE_URL=https://your-newapi-host/v1
# OPENAI_MODEL=mistralai/mistral-small-4-119b-2603
# 目标语言：zh-CN / en / ja …
TRANSLATE_TO=zh-CN
# 翻译限速（滑动窗口，默认 40 次/60s）
TRANSLATE_RATE_LIMIT=40
TRANSLATE_RATE_WINDOW_SEC=60

# 也兼容别名：
# LLM_API_KEY=
# LLM_BASE_URL=
# LLM_MODEL=

# —— GigaSpeech / HuggingFace streaming ——
# HF_TOKEN=hf_...
# GIGASPEECH_SUBSET=xs
# 限制 HF 缓存目录，避免占满磁盘：
# HF_HOME=/tmp/hf_home

