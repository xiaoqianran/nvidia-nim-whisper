# =============================================================================
# 复制为 .env 后填入真实值（.env 已被 gitignore，切勿提交真实 Key）
#   cp .env.example .env
#
# Key 配置两种方式任选（可混用，代码会合并去重）：
#   A) 文件：每行一个 nvapi-...（推荐，列表长时更清晰）
#      cp nvidia_api_keys.txt.example nvidia_api_keys.txt
#   B) 直接写在 .env：逗号分隔（适合少量 Key）
#      NVIDIA_API_KEYS=nvapi-xxx,nvapi-yyy
# =============================================================================

# —— HuggingFace（GigaSpeech 等 gated 数据集）——
# HF_TOKEN=hf_xxxxxxxx

# —— Whisper ASR（build.nvidia.com / Riva gRPC）——
# 方式 A：Key 文件（见 nvidia_api_keys.txt.example）
NVIDIA_API_KEYS_FILE=nvidia_api_keys.txt
# 方式 B：写在本文件（取消注释并替换）
# NVIDIA_API_KEYS=nvapi-whisper-key-1,nvapi-whisper-key-2
# 单 Key 也可用：
# NVIDIA_API_KEY=nvapi-whisper-only-one

# 每把 Key 独立滑动窗口限速
WHISPER_RATE_LIMIT=60
WHISPER_RATE_WINDOW_SEC=60

# —— 翻译（OpenAI 兼容 → integrate.api.nvidia.com）——
# 方式 A：
NVIDIA_TRANSLATE_API_KEYS_FILE=nvidia_translate_api_keys.txt
# 方式 B：
# NVIDIA_TRANSLATE_API_KEYS=nvapi-translate-key-1,nvapi-translate-key-2

OPENAI_BASE_URL=https://integrate.api.nvidia.com/v1
OPENAI_MODEL=mistralai/mistral-small-4-119b-2603
TRANSLATE_TO=zh-CN
TRANSLATE_RATE_LIMIT=60
TRANSLATE_RATE_WINDOW_SEC=60

# —— 总结（stepfun-ai/step-3.5-flash）——
# 方式 A：
NVIDIA_SUMMARIZE_API_KEYS_FILE=nvidia_summarize_api_keys.txt
# 方式 B：
# NVIDIA_SUMMARIZE_API_KEYS=nvapi-summarize-key-1,nvapi-summarize-key-2

SUMMARIZE_MODEL=stepfun-ai/step-3.5-flash
SUMMARIZE_RATE_LIMIT=40
SUMMARIZE_RATE_WINDOW_SEC=60
# step-3.5-flash 上下文约 262K tokens；默认单次约 18 万字，一般视频无需拆分
SUMMARIZE_MAX_CHUNK_CHARS=180000

# —— 可选：GigaSpeech 缓存目录 ——
# GIGASPEECH_SUBSET=xs
# HF_HOME=/path/to/small_cache
