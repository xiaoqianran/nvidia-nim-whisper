# 总结专用多 Key（每行一个 nvapi-...）
# 模型默认：stepfun-ai/step-3.5-flash
# 用法：
#   cp nvidia_summarize_api_keys.txt.example nvidia_summarize_api_keys.txt
# .env：
#   NVIDIA_SUMMARIZE_API_KEYS_FILE=nvidia_summarize_api_keys.txt
#   # 或：NVIDIA_SUMMARIZE_API_KEYS=nvapi-a,nvapi-b

nvapi-YOUR_SUMMARIZE_KEY_1
nvapi-YOUR_SUMMARIZE_KEY_2
